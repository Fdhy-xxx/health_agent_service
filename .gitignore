# ========================
# 1. 绝对不能提交的机密文件
# ========================
.env
*.pem
*.key

# ========================
# 2. 虚拟环境 (uv / venv)
# ========================
.venv/
venv/
env/

# ========================
# 3. Python 自动生成的缓存
# ========================
__pycache__/
*.py[cod]
*$py.class
*.so

# ========================
# 4. IDE 配置文件
# ========================
.idea/
.vscode/
*.swp
*.swo

# ========================
# 5. 操作系统自动生成的文件
# ========================
.DS_Store
Thumbs.db

# ========================
# 6. 日志与测试缓存
# ========================
*.log
.pytest_cache/
.ruff_cache/
.mypy_cache/